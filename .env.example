# React App Configuration
REACT_APP_API_URL=http://localhost:8000
REACT_APP_ENV=development

# CDN Configuration (Future CloudFront Implementation)
# Uncomment and replace with your CloudFront URL when ready
# REACT_APP_CDN_URL=https://d1234567890.cloudfront.net

# Image Optimization
REACT_APP_IMAGE_QUALITY=85
REACT_APP_IMAGE_FORMAT=webp

# Performance Monitoring
REACT_APP_ENABLE_PERFORMANCE_MONITORING=true
